# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Upstash Redis — added automatically when you link a Redis integration in the Vercel dashboard.
# For local dev, copy these from: Vercel Dashboard → Integrations → Upstash → your database → ".env.local" tab
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Giphy API key — free at https://developers.giphy.com (Create App → SDK)
NEXT_PUBLIC_GIPHY_KEY=

# Public site URL used for canonical/SEO metadata (production domain)
NEXT_PUBLIC_SITE_URL=https://gifbattles.com

# Sentry DSN for frontend + server error tracking
NEXT_PUBLIC_SENTRY_DSN=
# Optional server-only DSN override (if set, server/edge uses this instead of NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=
# Optional tracing sample rate in [0,1], default is 0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional: only needed if you want source map upload during build
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel Blob Storage - for local dev, create a read/write token in the Vercel dashboard: Settings → Blob Storage → Tokens → Create Token (read/write)
BLOB_READ_WRITE_TOKEN=
